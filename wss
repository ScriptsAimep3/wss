    hit.Size = UDim2.new(1,-26,1,0); hit.BackgroundTransparency=1; hit.Text=""
    hit.ZIndex=5; hit.Parent=row
    hit.MouseButton1Click:Connect(function()
        for _, r in ipairs(rows) do
            if r.f and r.f.Parent then r.f.BackgroundColor3=NRM_C end
        end
        row.BackgroundColor3 = SEL_C
        selected = e
        DetailTxt.Text = string.format(
            "[%s]  msg#%d  sock#%d  %s\nURL: %s\n\n%s",
            e.time, e.id, e.sockId, e.dir, e.url, e.data)
    end)
    hit.MouseEnter:Connect(function()
        if row.BackgroundColor3 ~= SEL_C then row.BackgroundColor3 = Color3.fromRGB(18,18,30) end
    end)
    hit.MouseLeave:Connect(function()
        if row.BackgroundColor3 ~= SEL_C then row.BackgroundColor3 = NRM_C end
    end)

    table.insert(rows, {f=row, e=e})
    CountLbl.Text = #msgs.." msgs"
    task.defer(function() List.CanvasPosition = Vector2.new(0,999999) end)
end

local function rebuildList()
    for _, r in ipairs(rows) do
        if r.f and r.f.Parent then r.f:Destroy() end
    end
    rows = {}
    for _, e in ipairs(msgs) do addRow(e) end
end

