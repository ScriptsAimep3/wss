-- HOOK WEBSOCKET — compatible con todos los execs
-- ═══════════════════════════════════════════════
local WS = WebSocket
if not WS then
    error("[WSSpy] WebSocket API no encontrada en este ejecutor.")
end

-- Obtener la función connect original de forma segura
local origConnect
do
    -- Intentar con getrawmetatable para leer sin restricciones
    local mt = getrawmetatable and getrawmetatable(WS)
    if mt then
        origConnect = rawget(mt, "connect") or rawget(mt, "__index") and rawget(rawget(mt, "__index"), "connect")
    end
    -- Si no, leer directo (puede funcionar en lectura aunque no en escritura)
    if not origConnect then
        origConnect = WS.connect
    end
end

assert(origConnect, "[WSSpy] No se pudo obtener WebSocket.connect")

-- ─── La función que reemplaza connect ─────────
local function hookedConnect(url)
    -- Llamar la función REAL
    local sock = origConnect(url)
    if not sock then return sock end

    local id = #sockets + 1
    sockets[id] = {
        id     = id,
        url    = url,
        status = "open",
        sent   = 0,
        recv   = 0,
    }
    if _G.WSSpy_NewSocket then
        task.spawn(_G.WSSpy_NewSocket, sockets[id])
    end

    -- Hook mensajes recibidos
    sock.OnMessage:Connect(function(data)
        sockets[id].recv += 1
        local e = {
            id     = #msgs + 1,
            sockId = id,
            url    = url,
            dir    = "RECV",
            data   = tostring(data),
            time   = os.date("%H:%M:%S"),
        }
        table.insert(msgs, e)
        if #msgs > MAX then table.remove(msgs, 1) end
        if _G.WSSpy_NewMsg then _G.WSSpy_NewMsg(e) end
    end)

    -- Hook OnClose
    sock.OnClose:Connect(function()
        sockets[id].status = "closed"
        if _G.WSSpy_SocketClose then _G.WSSpy_SocketClose(id) end
    end)

    -- Hook Send — también con hookfunction si es readonly
    local origSend
    local sendOk = pcall(function()
        origSend = sock.Send
        local newSend = function(self, data)
            sockets[id].sent += 1
            local e = {
                id     = #msgs + 1,
                sockId = id,
                url    = url,
                dir    = "SEND",
                data   = tostring(data),
                time   = os.date("%H:%M:%S"),
            }
            table.insert(msgs, e)
            if #msgs > MAX then table.remove(msgs, 1) end
            if _G.WSSpy_NewMsg then _G.WSSpy_NewMsg(e) end
            return origSend(self, data)
        end

        if hookfunction then
            hookfunction(origSend, newSend)
        elseif replaceclosure then
            replaceclosure(origSend, newSend)
        else
            sock.Send = newSend  -- último recurso
        end
    end)
    if not sendOk then
        warn("[WSSpy] No se pudo hookear Send — solo se capturarán RECV")
    end

    return sock
end

-- ─── Aplicar el hook con el método disponible ─
local hookApplied = false

-- Método 1: hookfunction (Synapse X, KRNL, Fluxus)
if not hookApplied and hookfunction then
    local ok, err = pcall(hookfunction, origConnect, hookedConnect)
    if ok then
        hookApplied = true
        print("[WSSpy] Hook via hookfunction ✓")
    else
        warn("[WSSpy] hookfunction falló:", err)
    end
end

-- Método 2: replaceclosure (algunos ejecutores)
if not hookApplied and replaceclosure then
    local ok, err = pcall(replaceclosure, origConnect, hookedConnect)
    if ok then
        hookApplied = true
        print("[WSSpy] Hook via replaceclosure ✓")
    else
        warn("[WSSpy] replaceclosure falló:", err)
    end
end

-- Método 3: setrawmetatable para desproteger la tabla
if not hookApplied then
    local ok, err = pcall(function()
        local mt = getrawmetatable(WS)
        local old__newindex = rawget(mt, "__newindex")
        -- Desactivar temporalmente __newindex
        setrawmetatable(WS, setmetatable({}, {
            __index    = mt,
            __newindex = function(t, k, v) rawset(t, k, v) end,
        }))
        WS.connect = hookedConnect
        -- Restaurar metatable original
        setrawmetatable(WS, mt)
    end)
    if ok then
        hookApplied = true
        print("[WSSpy] Hook via setrawmetatable ✓")
    else
        warn("[WSSpy] setrawmetatable falló:", err)
    end
end

-- Método 4: __newindex bypass directo
if not hookApplied then
    local ok, err = pcall(function()
        local mt = getrawmetatable(WS)
        local saved = rawget(mt, "__newindex")
        rawset(mt, "__newindex", nil)
        WS.connect = hookedConnect
        rawset(mt, "__newindex", saved)
    end)
    if ok then
        hookApplied = true
        print("[WSSpy] Hook via rawset mt ✓")
    else
        warn("[WSSpy] rawset mt falló:", err)
    end
end

if not hookApplied then
    warn("[WSSpy] ⚠ No se pudo hookear WebSocket.connect. Los mensajes no se capturarán automáticamente.")
    warn("[WSSpy] Intenta ejecutar el script ANTES de que cargue el juego.")
end

