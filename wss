    Instance.new("UICorner", card).CornerRadius = UDim.new(0,5)
    local cp = Instance.new("UIPadding", card)
    cp.PaddingLeft = UDim.new(0,7); cp.PaddingRight = UDim.new(0,7)
    local cl = Instance.new("UIListLayout", card)
    cl.FillDirection = Enum.FillDirection.Horizontal
    cl.VerticalAlignment = Enum.VerticalAlignment.Center
    cl.Padding = UDim.new(0,5)

    local dot = Instance.new("Frame")
    dot.Size = UDim2.new(0,8,0,8)
    dot.BackgroundColor3 = Color3.fromRGB(80,220,100)
    dot.BorderSizePixel  = 0
    dot.ZIndex           = 6
    dot.Parent           = card
    Instance.new("UICorner", dot).CornerRadius = UDim.new(1,0)

    local function lbl(txt, w, col, font)
        local l = Instance.new("TextLabel")
        l.Text           = txt
        l.Size           = UDim2.new(0, w, 1, 0)
        l.BackgroundTransparency = 1
        l.TextColor3     = col or Color3.fromRGB(210,210,230)
        l.Font           = font or Enum.Font.Code
        l.TextSize       = 10
        l.ZIndex         = 6
        l.Parent         = card
        return l
    end
    lbl("#"..s.id, 20, Color3.fromRGB(90,140,255), Enum.Font.GothamBold)
    local shortUrl = s.url:gsub("wss?://",""):sub(1, 30)
    lbl(shortUrl, math.clamp(#shortUrl*6, 60, 200))
    local statsL = lbl("↑0 ↓0", 44, Color3.fromRGB(110,110,150), Enum.Font.GothamSemibold)

    -- Copiar URL
    local cpBtn = Instance.new("TextButton")
    cpBtn.Text = "⎘"; cpBtn.Size = UDim2.new(0,20,0,20)
    cpBtn.BackgroundColor3 = Color3.fromRGB(28,58,128)
    cpBtn.TextColor3 = Color3.new(1,1,1)
    cpBtn.Font = Enum.Font.GothamBold; cpBtn.TextSize = 12
    cpBtn.BorderSizePixel = 0; cpBtn.ZIndex = 6; cpBtn.Parent = card
    Instance.new("UICorner", cpBtn).CornerRadius = UDim.new(0,4)
    cpBtn.MouseButton1Click:Connect(function()
        copy(s.url)
        cpBtn.Text = "✓"; cpBtn.BackgroundColor3 = Color3.fromRGB(28,105,50)
        task.delay(1.2, function()
            if cpBtn.Parent then
                cpBtn.Text = "⎘"; cpBtn.BackgroundColor3 = Color3.fromRGB(28,58,128)
            end
        end)
    end)

    sockCards[s.id] = { dot = dot, stats = statsL }

    task.spawn(function()
        while card.Parent do
            task.wait(0.5)
            local sc = sockets[s.id]
            if sc then
                statsL.Text = "↑"..sc.sent.." ↓"..sc.recv
                dot.BackgroundColor3 = sc.status == "open"
                    and Color3.fromRGB(80,220,100)
                    or  Color3.fromRGB(220,55,55)
            end
        end
    end)
end

